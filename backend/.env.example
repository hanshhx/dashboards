# 백엔드 실행 시 환경변수 (예: export $(grep -v '^#' .env | xargs))
DB_HOST=100.111.79.100
DB_PORT=5432
DB_NAME=suricata_db
DB_USER=dashboard_user
DB_PASSWORD=여기에_읽기전용_비밀번호
EVENTS_TABLE=events
# 프론트와 같은 서버에서 프록시로 연결하면 CORS는 사실상 불필요하지만, 직접 호출 대비 기본값 유지
CORS_ORIGINS=http://localhost:3000
# API 키 (공개 배포 시 필수). 생성: openssl rand -hex 32
# 비워두면 인증 비활성. /api/health 는 키 없이도 허용.
API_KEY=
